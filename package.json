{
  "private": true,
  "scripts": {
    "start": "pnpm --filter eva start",
    "android": "pnpm --filter eva android",
    "build:dev": "pnpm --filter eva build:dev",
    "build:preview": "pnpm --filter eva build:preview",
    "build:prod": "pnpm --filter eva build:prod",
    "update:dev": "pnpm --filter eva update:dev",
    "update:preview": "pnpm --filter eva update:preview",
    "dev": "pnpm --filter conductor dev",
    "turbo": "pnpm --filter conductor turbo",
    "convex": "pnpm --filter @conductor/backend dev",
    "convex:deploy": "pnpm --filter @conductor/backend run deploy",
    "ext:dev": "pnpm --filter eva-assist-extension dev",
    "ext:build": "pnpm --filter eva-assist-extension build",
    "ext:release": "npx tsx scripts/release-extension.ts",
    "desktop:dev": "pnpm --filter conductor-desktop dev",
    "desktop:build": "pnpm --filter conductor-desktop build",
    "desktop:dist": "pnpm --filter conductor-desktop dist",
    "mcp:dev": "pnpm --filter conductor-mcp dev",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.10",
      "@types/react-dom": "19.0.4"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "node-pty"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "@tanstack/react-hotkeys": "^0.3.2",
    "embla-carousel-react": "^8.6.0"
  }
}
