    "@react-navigation/native": "^7.0.0",
    "expo": "^52.0.21",
    "expo-constants": "~17.0.3",
    "expo-dev-client": "~5.0.4",
    "expo-dev-launcher": "^5.0.17",
    "expo-document-picker": "~13.0.1",
    "expo-file-system": "~18.0.6",
    "expo-intent-launcher": "~12.0.1",
    "expo-linking": "~7.0.3",
